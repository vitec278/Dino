<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <title>Динозавр — мобильная версия</title>
    <style>
        * {
            user-select: none;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Courier New', 'Press Start 2P', monospace;
            padding: 10px;
            touch-action: manipulation;
        }
        
        .game-container {
            background: white;
            padding: 15px;
            border-radius: 24px;
            box-shadow: 0 20px 35px rgba(0,0,0,0.3);
            max-width: 100%;
            position: relative;
            width: 100%;
            max-width: 500px;
        }
        
        canvas {
            display: block;
            margin: 0 auto;
            border: 3px solid #2c3e2f;
            border-radius: 12px;
            cursor: pointer;
            background: linear-gradient(to bottom, #87CEEB 0%, #FEF9E8 30%);
            width: 100%;
            height: auto;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            touch-action: none;
        }
        
        .info {
            display: flex;
            justify-content: space-between;
            margin-top: 12px;
            font-weight: bold;
            font-size: 0.9rem;
            background: #2c3e2f;
            color: #f7d44a;
            padding: 8px 15px;
            border-radius: 40px;
            flex-wrap: wrap;
            gap: 5px;
        }
        
        .info span {
            white-space: nowrap;
        }
        
        .controls {
            margin-top: 12px;
            text-align: center;
            font-size: 0.7rem;
            color: #3e5a3a;
        }
        
        .button-group {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 8px;
            flex-wrap: wrap;
        }
        
        button {
            background: #2c3e2f;
            border: none;
            color: #f7d44a;
            font-weight: bold;
            font-family: inherit;
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: 0.2s;
            touch-action: manipulation;
            min-width: 100px;
        }
        
        button:active {
            transform: scale(0.95);
            background: #1f2c1f;
        }
        
        .status {
            text-align: center;
            margin-top: 10px;
            font-size: 0.65rem;
            color: #666;
            padding: 5px;
        }
        
        /* Мобильные кнопки управления */
        .mobile-controls {
            display: none;
            justify-content: center;
            gap: 20px;
            margin-top: 15px;
        }
        
        .mobile-btn {
            background: #2c3e2f;
            border: none;
            color: #f7d44a;
            font-size: 1.5rem;
            padding: 12px 25px;
            border-radius: 50px;
            cursor: pointer;
            touch-action: manipulation;
            font-weight: bold;
            transition: 0.1s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        
        .mobile-btn:active {
            transform: scale(0.92);
            background: #1f2c1f;
        }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-3px); }
            75% { transform: translateX(3px); }
        }
        
        .shake {
            animation: shake 0.2s ease-in-out;
        }
        
        /* Всплывающее уведомление */
        .toast {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.8);
            color: #f7d44a;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-family: monospace;
            pointer-events: none;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.3s;
            white-space: nowrap;
        }
        
        .toast.show {
            opacity: 1;
        }
        
        /* Адаптация для маленьких экранов */
        @media (max-width: 600px) {
            .game-container {
                padding: 10px;
            }
            
            .info {
                font-size: 0.75rem;
                padding: 6px 12px;
            }
            
            button {
                padding: 6px 12px;
                font-size: 0.75rem;
                min-width: 80px;
            }
            
            .mobile-controls {
                display: flex;
            }
            
            .controls {
                display: none;
            }
        }
        
        @media (max-width: 400px) {
            .info span {
                font-size: 0.7rem;
            }
            
            .mobile-btn {
                padding: 8px 20px;
                font-size: 1.2rem;
            }
        }
        
        @media (hover: hover) {
            button:hover {
                transform: scale(1.02);
                background: #1f2c1f;
            }
        }
    </style>
</head>
<body>
<div class="game-container">
    <canvas id="gameCanvas" width="800" height="250"></canvas>
    <div class="info">
        <span>🦖 SCORE: <span id="scoreValue">0</span></span>
        <span>⚡ SPEED: <span id="speedValue">1.0</span>x</span>
        <span>🏆 BEST: <span id="bestValue">0</span></span>
    </div>
    <div class="controls">
        ␣ ПРОБЕЛ / ▲ / ТАП — прыжок | R / 🔄 — рестарт
    </div>
    <div class="button-group">
        <button id="restartButton">🔄 Новая игра</button>
        <button id="soundButton">🔊 Звук: ВКЛ</button>
    </div>
    <div class="mobile-controls">
        <button class="mobile-btn" id="mobileJumpBtn">🦘 ПРЫЖОК</button>
        <button class="mobile-btn" id="mobileRestartBtn">🔄 РЕСТАРТ</button>
    </div>
    <div class="status" id="gameStatus">🏃‍♂️ Нажмите на экран чтобы начать!</div>
</div>
<div id="toast" class="toast"></div>

<script>
    // ----- Элементы -----
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreSpan = document.getElementById('scoreValue');
    const speedSpan = document.getElementById('speedValue');
    const bestSpan = document.getElementById('bestValue');
    const soundButton = document.getElementById('soundButton');
    const gameStatus = document.getElementById('gameStatus');
    const toast = document.getElementById('toast');
    
    // ----- Оптимизация для мобильных -----
    let lastTimestamp = 0;
    let frameCount = 0;
    let lastFpsUpdate = 0;
       
    // ----- Параметры игры -----
    let gameRunning = false;
    let gameStarted = false;
    let score = 0;
    let bestScore = localStorage.getItem('dinoBest') ? parseInt(localStorage.getItem('dinoBest')) : 0;
    bestSpan.innerText = bestScore;
    
    // ----- Звуковая система с оптимизацией для мобильных -----
    let soundEnabled = true;
    let audioContext = null;
    
    function initAudio() {
        if (!audioContext && (soundEnabled)) {
            try {
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                // Не запускаем сразу, ждём взаимодействия пользователя
            } catch(e) {
                console.log('Web Audio API not supported');
            }
        }
    }
    
    function playJumpSound() {
        if (!soundEnabled || !gameRunning) return;
        try {
            if (!audioContext) {
                initAudio();
                if (!audioContext) return;
            }
            // Возобновляем контекст если он приостановлен
            if (audioContext.state === 'suspended') {
                audioContext.resume();
            }
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            oscillator.frequency.value = 800;
            gainNode.gain.value = 0.08;
            oscillator.type = 'sine';
            oscillator.start();
            gainNode.gain.exponentialRampToValueAtTime(0.00001, audioContext.currentTime + 0.25);
            oscillator.stop(audioContext.currentTime + 0.25);
        } catch(e) { /* fallback */ }
    }
    
    function playCrashSound() {
        if (!soundEnabled) return;
        try {
            if (!audioContext) {
                initAudio();
                if (!audioContext) return;
            }
            if (audioContext.state === 'suspended') {
                audioContext.resume();
            }
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            oscillator.frequency.value = 200;
            gainNode.gain.value = 0.15;
            oscillator.type = 'sawtooth';
            oscillator.start();
            gainNode.gain.exponentialRampToValueAtTime(0.00001, audioContext.currentTime + 0.4);
            oscillator.stop(audioContext.currentTime + 0.4);
        } catch(e) { /* fallback */ }
    }
    
    // ----- Динозавр -----
    const dino = {
        x: 70,
        y: 0,
        width: 28,
        height: 28,
        groundY: 0,
        isJumping: false,
        ySpeed: 0,
        gravity: 0.8,
        jumpPower: -11,
        frame: 0,
        legCycle: 0,
        isDucking: false,
        lastJumpTime: 0
    };
    
    // ----- Препятствия -----
    let obstacles = [];
    let particles = [];
    let frameCounter = 0;
    let baseSpeed = 4;
    let currentSpeed = baseSpeed;
    
    // ----- Частицы для эффектов -----
    class Particle {
        constructor(x, y, vx, vy) {
            this.x = x;
            this.y = y;
            this.vx = vx;
            this.vy = vy;
            this.life = 1;
            this.gravity = 0.2;
        }
        
        update() {
            this.x += this.vx;
            this.y += this.vy;
            this.vy += this.gravity;
            this.life -= 0.02;
            return this.life > 0;
        }
        
        draw() {
            ctx.fillStyle = `rgba(255, 200, 100, ${this.life})`;
            ctx.fillRect(this.x, this.y, 3, 3);
        }
    }
    
    // ----- Генерация препятствий -----
    function spawnObstacle() {
        const random = Math.random();
        let type, width, height, color;
        
        if (random < 0.35) {
            type = 'singleCactus';
            width = 12;
            height = 24;
            color = '#2d5a2d';
        } else if (random < 0.65) {
            type = 'doubleCactus';
            width = 26;
            height = 24;
            color = '#2d5a2d';
        } else if (random < 0.85) {
            type = 'bush';
            width = 24;
            height = 12;
            color = '#5a8f4c';
        } else {
            type = 'rock';
            width = 18;
            height = 10;
            color = '#8b7355';
        }
        
        obstacles.push({
            x: canvas.width,
            y: dino.groundY + dino.height - height,
            width: width,
            height: height,
            type: type,
            color: color
        });
    }
    
    // ----- Инициализация -----
    function initGround() {
        dino.groundY = canvas.height - dino.height - 5;
        dino.y = dino.groundY;
    }
    
    function showToast(message, duration = 1500) {
        toast.textContent = message;
        toast.classList.add('show');
        setTimeout(() => {
            toast.classList.remove('show');
        }, duration);
    }
    
    function resetGame() {
        gameRunning = true;
        gameStarted = true;
        score = 0;
        currentSpeed = baseSpeed;
        updateScoreUI();
        obstacles = [];
        particles = [];
        frameCounter = 0;
        dino.isJumping = false;
        dino.ySpeed = 0;
        dino.y = dino.groundY;
        dino.frame = 0;
        gameStatus.textContent = '🏃‍♂️ Игра началась! Удачи!';
        gameStatus.style.color = '#4caf50';
        showToast('🚀 Новая игра!');
        setTimeout(() => {
            if(gameRunning) gameStatus.textContent = '⚡ Игра активна!';
        }, 2000);
    }
    
    function updateScoreUI() {
        scoreSpan.innerText = Math.floor(score);
        if (Math.floor(score) > bestScore) {
            bestScore = Math.floor(score);
            bestSpan.innerText = bestScore;
            localStorage.setItem('dinoBest', bestScore);
            if (Math.floor(score) > 0 && Math.floor(score) % 100 === 0) {
                showToast(`🎉 Новый рекорд! ${bestScore} 🎉`);
            }
        }
        // Обновляем скорость
        currentSpeed = baseSpeed + Math.floor(score / 400);
        speedSpan.innerText = (currentSpeed / baseSpeed).toFixed(1);
    }
    
    // ----- Обновление физики и логики -----
    function updateGame() {
        if (!gameRunning) return;
        
        // 1. Физика динозавра
        if (dino.isJumping) {
            dino.ySpeed += dino.gravity;
            dino.y += dino.ySpeed;
            if (dino.y >= dino.groundY) {
                dino.y = dino.groundY;
                dino.isJumping = false;
                dino.ySpeed = 0;
                // Добавляем частицы при приземлении
                for(let i = 0; i < 5; i++) {
                    particles.push(new Particle(dino.x + dino.width/2, dino.y + dino.height, 
                        (Math.random() - 0.5) * 3, -Math.random() * 2));
                }
            }
        }
        
        // Анимация ног
        if (!dino.isJumping && gameRunning) {
            dino.frame++;
            if (dino.frame > 15) {
                dino.frame = 0;
                dino.legCycle = (dino.legCycle + 1) % 2;
            }
        }
        
        // 2. Движение препятствий
        for (let i = 0; i < obstacles.length; i++) {
            obstacles[i].x -= currentSpeed;
            if (obstacles[i].x + obstacles[i].width < 0) {
                obstacles.splice(i,1);
                i--;
            }
        }
        
        // 3. Спавн препятствий
        frameCounter++;
        let dynamicGap = Math.max(35, 70 - Math.floor(score / 250));
        if (frameCounter >= dynamicGap && gameRunning) {
            frameCounter = 0;
            spawnObstacle();
        }
        
        // 4. Коллизия
        for (let obs of obstacles) {
            if (dino.x < obs.x + obs.width &&
                dino.x + dino.width > obs.x &&
                dino.y < obs.y + obs.height &&
                dino.y + dino.height > obs.y) {
                gameRunning = false;
                playCrashSound();
                gameStatus.textContent = '💀 GAME OVER! Нажмите R чтобы продолжить 💀';
                gameStatus.style.color = '#f44336';
                showToast('💀 Игра окончена! 💀');
                // Эффект тряски
                document.querySelector('.game-container').classList.add('shake');
                setTimeout(() => {
                    document.querySelector('.game-container').classList.remove('shake');
                }, 200);
                break;
            }
        }
        
        // 5. Обновление частиц
        particles = particles.filter(p => p.update());
        
        // 6. Начисление очков
        if (gameRunning) {
            score += 0.12 * (1 + Math.floor(score / 1000) * 0.05);
            updateScoreUI();
        }
    }
    
    // ----- Отрисовка всего (оптимизированная для мобильных) -----
    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // Небо
        ctx.fillStyle = '#87CEEB';
        ctx.fillRect(0, 0, canvas.width, canvas.height - 50);
        
        // Облака (упрощённая анимация для производительности)
        const time = Date.now() * 0.01;
        ctx.fillStyle = 'rgba(255,255,255,0.8)';
        ctx.beginPath();
        ctx.ellipse(100 + time % 800, 50, 30, 25, 0, 0, Math.PI*2);
        ctx.ellipse(120 + time % 800, 45, 35, 30, 0, 0, Math.PI*2);
        ctx.ellipse(80 + time % 800, 45, 25, 20, 0, 0, Math.PI*2);
        ctx.fill();
        
        ctx.beginPath();
        ctx.ellipse(500 + (time * 0.75) % 800, 70, 35, 28, 0, 0, Math.PI*2);
        ctx.ellipse(525 + (time * 0.75) % 800, 65, 40, 33, 0, 0, Math.PI*2);
        ctx.ellipse(475 + (time * 0.75) % 800, 65, 30, 25, 0, 0, Math.PI*2);
        ctx.fill();
        
        // Земля
        ctx.fillStyle = '#d9c8a9';
        ctx.fillRect(0, dino.groundY + dino.height, canvas.width, 8);
        ctx.fillStyle = '#b59a6b';
        ctx.fillRect(0, dino.groundY + dino.height + 5, canvas.width, 4);
        
        // Трава (упрощённая)
        ctx.fillStyle = '#6b8c42';
        for(let i = 0; i < 8; i++) {
            let x = (Date.now() * 0.3 + i * 70) % canvas.width;
            ctx.fillRect(x, dino.groundY + dino.height - 3, 2, 6);
        }
        
        // Препятствия
        for (let obs of obstacles) {
            ctx.fillStyle = obs.color;
            ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
            
            // Детали препятствий
            if (obs.type === 'doubleCactus') {
                ctx.fillStyle = '#1e3a1e';
                ctx.fillRect(obs.x + 4, obs.y - 4, 5, 5);
                ctx.fillRect(obs.x + 15, obs.y - 4, 5, 5);
            } else if (obs.type === 'bush') {
                ctx.fillStyle = '#4c7a3a';
                for(let i = 0; i < 3; i++) {
                    ctx.beginPath();
                    ctx.arc(obs.x + 5 + i*6, obs.y - 3, 4, 0, Math.PI*2);
                    ctx.fill();
                }
            } else if (obs.type === 'rock') {
                ctx.fillStyle = '#5a4a3a';
                ctx.beginPath();
                ctx.moveTo(obs.x + obs.width/2, obs.y - 5);
                ctx.lineTo(obs.x + obs.width-2, obs.y);
                ctx.lineTo(obs.x + 2, obs.y);
                ctx.fill();
            }
        }
        
        // Динозавр
        ctx.fillStyle = '#4c8b3c';
        ctx.fillRect(dino.x, dino.y, dino.width, dino.height);
        
        // Ноги
        if (!dino.isJumping) {
            ctx.fillStyle = '#3a6b2a';
            if (dino.legCycle === 0) {
                ctx.fillRect(dino.x + 5, dino.y + dino.height-5, 6, 8);
                ctx.fillRect(dino.x + 17, dino.y + dino.height-8, 6, 11);
            } else {
                ctx.fillRect(dino.x + 5, dino.y + dino.height-8, 6, 11);
                ctx.fillRect(dino.x + 17, dino.y + dino.height-5, 6, 8);
            }
        } else {
            ctx.fillRect(dino.x + 5, dino.y + dino.height-5, 6, 8);
            ctx.fillRect(dino.x + 17, dino.y + dino.height-5, 6, 8);
        }
        
        // Глаз
        ctx.fillStyle = 'white';
        ctx.fillRect(dino.x + dino.width-8, dino.y+6, 6, 6);
        ctx.fillStyle = '#0a0a0a';
        ctx.fillRect(dino.x + dino.width-7, dino.y+7, 3, 4);
        
        // Зрачок при прыжке
        if (dino.isJumping) {
            ctx.fillStyle = 'white';
            ctx.fillRect(dino.x + dino.width-9, dino.y+5, 2, 2);
        }
        
        // Шипы
        ctx.fillStyle = '#2a5a1a';
        ctx.fillRect(dino.x+5, dino.y-4, 5 5);
        ctx.fillRect(dino.x+14, dino.y-4, 5, 5);
        
        // Частицы
        particles.forEach(p => p.draw());
        
        // Состояния игры
        if (!gameRunning && gameStarted) {
            ctx.fillStyle = 'rgba(0,0,0,0.75)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#f7d44a';
            ctx.font = 'bold 24px "Courier New"';
            ctx.fillText('GAME OVER', canvas.width/2-90, canvas.height/2-20);
            ctx.font = '12px monospace';
            ctx.fillStyle = '#eee';
            ctx.fillText('Нажмите кнопку или R', canvas.width/2-110, canvas.height/2+30);
        } else if (!gameStarted) {
            ctx.fillStyle = 'rgba(0,0,0,0.6)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#f7d44a';
            ctx.font = 'bold 18px "Courier New"';
            ctx.fillText('ТАПНИ ПО ЭКРАНУ', canvas.width/2-105, canvas.height/2);
            ctx.font = '11px monospace';
            ctx.fillStyle = '#ddd';
            ctx.fillText('чтобы начать игру', canvas.width/2-65, canvas.height/2+30);
        }
        
        // Информация о скорости
        ctx.font = 'bold 9px monospace';
        ctx.fillStyle = '#2c3e2f';
        ctx.fillText(`Скорость: ${currentSpeed.toFixed(1)}`, canvas.width-65, 18);
    }
    
    // ----- Прыжок с защитой от спама -----
    let jumpCooldown = false;
    
    function jump() {
        if (!gameRunning && gameStarted) return;
        if (!gameStarted) {
            // Инициализируем аудио при первом взаимодействии
            initAudio();
            resetGame();
            return;
        }
        
        const now = Date.now();
        if (jumpCooldown || (now - dino.lastJumpTime < 200)) return;
        
        if (!dino.isJumping && dino.y >= dino.groundY - 0.5) {
            dino.isJumping = true;
            dino.ySpeed = dino.jumpPower;
            dino.lastJumpTime = now;
            playJumpSound();
            
            // Визуальная обратная связь
            jumpCooldown = true;
            setTimeout(() => { jumpCooldown = false; }, 150);
        }
    }
    
    // ----- Обработчики с поддержкой touch -----
    let touchStartTime = 0;
    
    function handleKey(e) {
        const key = e.key;
        if (key === ' ' || key === 'ArrowUp' || key === 'Space') {
            e.preventDefault();
            jump();
        }
        if (key === 'r' || key === 'R' || key === 'к' || key === 'К') {
            e.preventDefault();
            resetGame();
        }
    }
    
    function handleTouch(e) {
        e.preventDefault();
        const touch = e.touches[0];
        const now = Date.now();
        
        // Избегаем двойных прыжков
        if (now - touchStartTime < 200) return;
        touchStartTime = now;
        
        jump();
    }
    
    // ----- Анимационный цикл с оптимизацией -----
    let animationId = null;
    
    function gameLoop() {
        updateGame();
        draw();
        animationId = requestAnimationFrame(gameLoop);
    }
    
    // ----- Старт игры -----
    function init() {
        initGround();
        gameLoop();
        
        // События
        window.addEventListener('keydown', handleKey);
        document.getElementById('restartButton').addEventListener('click', () => resetGame());
        document.getElementById('mobileJumpBtn')?.addEventListener('click', (e) => {
            e.preventDefault();
            jump();
        });
        document.getElementById('mobileRestartBtn')?.addEventListener('click', (e) => {
            e.preventDefault();
            resetGame();
        });
        
        canvas.addEventListener('touchstart', handleTouch, { passive: false });
        canvas.addEventListener('click', (e) => {
            e.preventDefault();
            jump();
        });
        
        // Звук кнопка
        soundButton.addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            soundButton.textContent = soundEnabled ? '🔊 Звук: ВКЛ' : '🔇 Звук: ВЫКЛ';
            if (soundEnabled && !audioContext) {
                initAudio();
            }
            showToast(soundEnabled ? '🔊 Звук включён' : '🔇 Звук выключен');
        });
        
        gameStatus.textContent = '🎮 Тапни по экрану чтобы начать!';
        
        // Предзагрузка аудио контекста
        document.body.addEventListener('touchstart', function initAudioOnce() {
            initAudio();
            document.body.removeEventListener('touchstart', initAudioOnce);
        }, { once: true });
    }
    
    init();
</script>
</body>
</html>
